# ============================================
# PROJECT CONFIGURATION
# ============================================
# Project name (used for container naming)
PROJECT_NAME=Quizly

# Domain name (use localhost for local development)
DOMAIN=localhost

# ============================================
# REPOSITORY CONFIGURATION
# ============================================
# Backend repository URL
BACKEND_REPO_URL=https://github.com/pirus99/Quizly.git
BACKEND_REPO_BRANCH=main

# Frontend repository URL
FRONTEND_REPO_URL=https://github.com/Developer-Akademie-Backendkurs/project.Quizly.git
FRONTEND_REPO_BRANCH=main

# ============================================
# TRAEFIK CONFIGURATION
# ============================================
# HTTP and HTTPS ports
HTTP_PORT=80
HTTPS_PORT=443

# Traefik Dashboard (set to true to enable)
TRAEFIK_DASHBOARD=false
TRAEFIK_DASHBOARD_PORT=8080

# Traefik logging
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_ACCESS_LOG=false

# ============================================
# DJANGO BACKEND CONFIGURATION
# ============================================
# Django secret key (generate a secure random string for production)
# You can generate one with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=change-me-to-a-secure-random-string-in-production

# Django debug mode (NEVER set to True in production)
DJANGO_DEBUG=False

# Allowed hosts (comma-separated, or * for all)
ALLOWED_HOSTS=*

# ============================================
# CORS CONFIGURATION
# ============================================
# Allow all origins (set to False and configure specific origins in production)
CORS_ALLOW_ALL_ORIGINS=True

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Frontend API URL (relative path preferred for same-domain deployment)
FRONTEND_API_URL=/api/
FRONTEND_STATIC_URL=/

# ============================================
# DJANGO SUPERUSER (OPTIONAL)
# ============================================
# Automatically create a superuser on first run (leave empty to skip)
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# ===========================================
# Quizly CONFIGURATION
# ==========================================
OPENAI_ENDPOINT=https://openrouter.ai/api/v1 #Your OpenAI-Compatible endpoint URL here
OPENAI_API_KEY=SUPER_SECRET_DEMO_KEY #Your OpenAI Provider API key here
OPENAI_MODEL="meta-llama/llama-3.3-70b-instruct:free" #Choose your OpenAI model here (e.g., gpt-4o, gpt-4o-mini, gpt-3.5-turbo, etc.)
WHISPER_MODEL="tiny" #Choose your Whisper model here (e.g., tiny(1GB), base(1GB), small(2GB), medium(5GB), large(10GB), turbo(6GB))

